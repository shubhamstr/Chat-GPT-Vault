{
    "manifest_version": 3,
    "name": "ChatGPT Project Manager",
    "version": "0.0.1",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://chatgpt.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}